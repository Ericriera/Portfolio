---
import AboutmeIcon from "./AboutmeIcon.astro"

const text1 = "I'm Eric Riera, a Backend Developer specialized in Python and Django, with experience building and maintaining production-ready APIs using Django Rest Framework."
const text2 = "I focus on clean architecture, modular design, and integrations with external systems (HTTP, SOAP, HL7). I’ve worked on scalable backend solutions, implementing authentication mechanisms like 2FA and ensuring code quality through automated testing with pytest."
const text3 = "Although I'm comfortable working across the full stack with Vue 3, my main focus is backend development and system design. I'm currently preparing for the Cambridge Advanced (C1) English certification. Outside of work, I enjoy playing basketball, building personal projects, and exploring new technologies."

const age = new Date().getFullYear() - 2002 - (new Date() < new Date(new Date().getFullYear(), 2, 11));
const workingYears = new Date().getFullYear() - 2023;
const countries = 14;
const ballinYears = new Date().getFullYear() - 2009;
---

<section id="aboutme" class="px-5 py-8 md:p-12 max-w-4xl mx-auto">
    <h3 class="text-4xl font-bold text-center  mb-8">About me 🙋🏻‍♂️</h3>
    <section class="px-5 py-5 bg-neutral-800/40 backdrop-blur-md border border-white/10 my-5 rounded-xl">
        <p class="mb-2">{text1}</p>
        <p class="mb-2">{text2}</p>
        <p>{text3}</p>
    </section>
    <section class="flex flex-wrap justify-around items-center w-full">
        <AboutmeIcon name="fa6-solid:cake-candles" data={age} text="years old" />
        <AboutmeIcon name="fa6-solid:graduation-cap" text="Graduate's" />
        <AboutmeIcon name="fa6-solid:laptop-code" data={workingYears} text="years working" />
        <AboutmeIcon name="fa6-solid:map" data={countries} text="countries visited" link="/travel" />
        <AboutmeIcon name="fa6-solid:basketball" data={ballinYears} text="years ballin'" />
    </section>
</section>